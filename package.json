{
  "name": "opensmartcharge",
  "version": "0.1.0",
  "description": "Lean, modular OCPP smart charging system",
  "type": "module",
  "scripts": {
    "dev": "tsx src/core/lifecycle.ts",
    "build": "tsc",
    "start": "node dist/core/lifecycle.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "sim:pulse": "node scripts/sim-pulse.mjs"
  },
  "dependencies": {
    "express": "^5.1.0",
    "mqtt": "^5.10.1",
    "ocpp-rpc": "^2.2.1",
    "pino": "^9.6.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.21",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  },
  "engines": {
    "node": ">=22.5"
  },
  "license": "MIT"
}
